<Window x:Class="Triathlon.Client.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Triathlon - Panou Arbitru" Height="500" Width="700"
        WindowStartupLocation="CenterScreen">
    <DockPanel Margin="10">
        <Border DockPanel.Dock="Top" Background="#F4F4F4" Padding="10" CornerRadius="5" Margin="0,0,0,10">
            <Grid>
                <Label x:Name="WelcomeLabel" x:FieldModifier="public" Content="Arbitru: -" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button x:Name="LogoutButton" x:FieldModifier="public" Content="Logout" HorizontalAlignment="Right" Padding="15,5" 
                        Background="#D9534F" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </Grid>
        </Border>

        <TabControl Background="White">
            <TabItem Header="Participanți (Alfabetic)">
                <DockPanel Margin="10">
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                        <Label Content="Adaugă puncte:" VerticalAlignment="Center"/>
                        <TextBox x:Name="PointsField" x:FieldModifier="public" Width="60" Margin="10,0" VerticalContentAlignment="Center"/>
                        <Button x:Name="SaveButton" x:FieldModifier="public" Content="Salvează Rezultat" Padding="15,5" Background="#5CB85C" 
                                Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                    
                    <DataGrid x:Name="AllParticipantsTable" x:FieldModifier="public" AutoGenerateColumns="False" IsReadOnly="True"
                              ItemsSource="{Binding Participants, UpdateSourceTrigger=PropertyChanged}" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nume Participant" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Punctaj Total" Binding="{Binding TotalPoints}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="Raport Proba Mea">
                <Grid Margin="10">
                    <DataGrid x:Name="ReportTable" x:FieldModifier="public" AutoGenerateColumns="False" IsReadOnly="True"
                              ItemsSource="{Binding Report, UpdateSourceTrigger=PropertyChanged}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Participant" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Punctaj" Binding="{Binding TotalPoints}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>