<Window x:Class="Triathlon.Client.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Triathlon - Autentificare" Height="300" Width="350" 
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center">
            <Label Content="Autentificare Arbitru" FontSize="20" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>
            
            <TextBlock Text="Username:" Margin="0,5,0,0"/>
            <TextBox x:Name="UsernameField" x:FieldModifier="public" Height="30" VerticalContentAlignment="Center"/>
            
            <TextBlock Text="Parolă:" Margin="0,10,0,0"/>
            <PasswordBox x:Name="PasswordField" x:FieldModifier="public" Height="30" VerticalContentAlignment="Center"/>
            
            <Button x:Name="LoginButton" x:FieldModifier="public" Content="Login" Margin="0,25,0,0" Height="35" 
                    Background="#2196F3" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>